<Project Sdk="Godot.NET.Sdk/4.6.2">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>HoldTheLine.Game</RootNamespace>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <!-- docs/15 §1: single source of truth for the CLIENT app version (distinct from RulesInfo.Version).
         Read at runtime via GameConfig.ClientVersion and by scripts/release.ps1 to drive vpk/git tag/version.json.
         Bump here only; the release script picks it up. SemVer Major.Minor.Patch. -->
    <Version>0.7.5</Version>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\src\HoldTheLine.Rules\HoldTheLine.Rules.csproj" />
    <ProjectReference Include="..\src\HoldTheLine.Net\HoldTheLine.Net.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- docs/15 §3 通道 A: in-app auto-update over GitHub Releases. VelopackApp.Build().Run() runs in the
         earliest autoload (UpdateService); UpdateManager drives check/download/apply-and-restart. -->
    <PackageReference Include="Velopack" Version="1.2.0" />
  </ItemGroup>
</Project>
